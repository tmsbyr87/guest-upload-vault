# Exclude repository and handoff artifacts from release archives.
/.DS_Store export-ignore
/.gitignore export-ignore
/.gitattributes export-ignore
/README.md export-ignore
/CHANGELOG.md export-ignore
/docs export-ignore
/guest-upload-vault/.DS_Store export-ignore

# Translation packaging rules:
# - keep runtime files in release (.mo/.po)
# - source template (.pot) can be excluded
/guest-upload-vault/languages/*.mo -export-ignore
/guest-upload-vault/languages/*.po -export-ignore
/guest-upload-vault/languages/guest-upload-vault.pot export-ignore
